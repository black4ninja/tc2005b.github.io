# Copia este archivo como .env y sustituye los valores por los de tu proyecto Supabase.
# NUNCA subas el archivo .env a tu repositorio. El .gitignore ya lo excluye.

# Cadena de conexión de Postgres (topbar > botón Connect > tab "Session pooler" > URI).
# Usa el session pooler (puerto 5432) — es el default recomendado para un servidor Express
# persistente. Evita el Transaction pooler (:6543) para este lab: algunas redes bloquean
# ese puerto y tu app quedará colgada sin error visible.
# Los esquemas postgres:// y postgresql:// son equivalentes.
DATABASE_URL=postgresql://postgres.xxxxxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Credenciales para el cliente JS de Supabase (Project Settings > API Keys)
# Usa la "Publishable key" (sb_publishable_...), NO el tab legacy de anon/service_role.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
