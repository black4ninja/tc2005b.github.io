# Cadena de conexión a tu base PostgreSQL en Supabase (Session pooler, puerto 5432).
# La sacas de: Supabase Dashboard -> botón "Connect" -> opción "Session pooler".
# Reemplaza [YOUR-PASSWORD] por la contraseña que generaste al crear el proyecto.
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# URL pública de tu proyecto. La sacas de: Project Settings -> API Keys.
SUPABASE_URL=https://xxxxxxxx.supabase.co

# LLAVE SECRETA — bypassea Row Level Security. Solo va en código servidor.
# JAMÁS la incluyas en código que llegue al navegador o a una app móvil.
# La sacas de: Project Settings -> API Keys -> Secret key (sb_secret_...).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nombres de los buckets que creaste en Storage. Si los nombraste distinto, cámbialos.
PUBLIC_BUCKET=lab28-public
PRIVATE_BUCKET=lab28-private
