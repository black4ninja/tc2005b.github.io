<!DOCTYPE HTML>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Documentos — Lab28StorageSupabase</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 2rem; background: #f9fafb; color: #111827; }
        h1 { margin-bottom: 0.2rem; }
        .meta { color: #6b7280; margin-bottom: 1.5rem; }
        .toolbar { margin-bottom: 1rem; }
        .toolbar a { background: #111827; color: white; padding: 0.5rem 0.9rem; border-radius: 4px; text-decoration: none; }
        table { width: 100%; border-collapse: collapse; background: white; }
        th, td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #e5e7eb; text-align: left; vertical-align: middle; }
        th { background: #111827; color: white; }
        tr:hover { background: #f3f4f6; }
        .thumb { max-width: 80px; max-height: 60px; border-radius: 4px; display: block; }
        .badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 999px; font-size: 0.75rem; }
        .badge-pub { background: #dcfce7; color: #166534; }
        .badge-prv { background: #fee2e2; color: #991b1b; }
        .flash { background: #dbeafe; border-left: 4px solid #2563eb; padding: 0.5rem 0.9rem; margin-bottom: 1rem; color: #1e3a8a; }
        form.inline { display: inline; }
        button.danger { background: #dc2626; color: white; border: none; padding: 0.3rem 0.6rem; border-radius: 4px; cursor: pointer; }
        .actions a, .actions button { margin-right: 0.4rem; }
    </style>
</head>
<body>
    <h1>Documentos</h1>
    <p class="meta">CRUD respaldado por Postgres + Supabase Storage</p>

    <% if (flash === 'creado') { %><div class="flash">Documento creado.</div><% } %>
    <% if (flash === 'actualizado') { %><div class="flash">Documento actualizado.</div><% } %>
    <% if (flash === 'reemplazado') { %><div class="flash">Archivo reemplazado.</div><% } %>
    <% if (flash === 'eliminado') { %><div class="flash">Documento eliminado.</div><% } %>

    <div class="toolbar">
        <a href="/documents/new">+ Nuevo documento</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Preview</th>
                <th>Título</th>
                <th>Tipo</th>
                <th>Tamaño</th>
                <th>Visibilidad</th>
                <th>Subido</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% docs.forEach(doc => { %>
                <tr>
                    <td><%= doc.id %></td>
                    <td>
                        <% if (doc.is_public && doc.mime_type && doc.mime_type.startsWith('image/')) { %>
                            <img class="thumb" src="<%= doc.publicUrl %>" alt="<%= doc.title %>">
                        <% } else if (!doc.is_public && doc.mime_type && doc.mime_type.startsWith('image/')) { %>
                            <img class="thumb" data-signed-id="<%= doc.id %>" alt="(privado)">
                        <% } else { %>
                            <span>—</span>
                        <% } %>
                    </td>
                    <td><a href="/documents/<%= doc.id %>"><%= doc.title %></a></td>
                    <td><%= doc.mime_type || '' %></td>
                    <td><%= doc.size_bytes ? (doc.size_bytes / 1024).toFixed(1) + ' KB' : '' %></td>
                    <td>
                        <% if (doc.is_public) { %>
                            <span class="badge badge-pub">público</span>
                        <% } else { %>
                            <span class="badge badge-prv">privado</span>
                        <% } %>
                    </td>
                    <td><%= new Date(doc.uploaded_at).toLocaleString('es-MX') %></td>
                    <td class="actions">
                        <a href="/documents/<%= doc.id %>/edit">editar</a>
                        <form class="inline" method="post" action="/documents/<%= doc.id %>/delete"
                              onsubmit="return confirm('¿Eliminar el documento y su archivo?')">
                            <button class="danger" type="submit">eliminar</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
            <% if (docs.length === 0) { %>
                <tr><td colspan="8" style="text-align:center;color:#6b7280;padding:1.5rem;">Sin documentos todavía.</td></tr>
            <% } %>
        </tbody>
    </table>

    <script>
        // Para los thumbnails de documentos privados, pedimos una signed URL
        // por cada uno y la asignamos al src. Esto demuestra el flujo
        // browser -> servidor -> Supabase sin exponer la secret key.
        document.querySelectorAll('img[data-signed-id]').forEach(async img => {
            const id = img.getAttribute('data-signed-id');
            const r = await fetch('/documents/' + id + '/signed-url');
            if (!r.ok) return;
            const { url } = await r.json();
            if (url) img.src = url;
        });
    </script>
</body>
</html>
